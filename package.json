{
  "name": "simulacra",
  "version": "0.1.0",
  "description": "A hierarchical multi-agent orchestrator built on Claude Code",
  "type": "module",
  "main": "dist/orchestrator.js",
  "scripts": {
    "start": "tsx src/orchestrator.ts",
    "orch:start": "bash scripts/orch.sh start",
    "orch:stop": "bash scripts/orch.sh stop",
    "orch:restart": "bash scripts/orch.sh restart",
    "orch:status": "bash scripts/orch.sh status",
    "orch:logs": "bash scripts/orch.sh logs",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest",
    "test:run": "vitest run",
    "check-api": "node scripts/check-api-key.mjs",
    "ui": "tsx src/ui/server.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.55.0",
    "@types/express": "^5.0.6",
    "@types/ws": "^8.18.1",
    "@xenova/transformers": "^2.17.2",
    "chokidar": "^3.6.0",
    "express": "^5.2.1",
    "js-yaml": "^4.1.0",
    "ws": "^8.19.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
